#include <stdio.h>

int main() {

    int startBlock, length, i;

    printf("Enter starting block: ");
    scanf("%d", &startBlock);

    printf("Enter length of file: ");
    scanf("%d", &length);

    printf("\nAllocated Blocks:\n");

    for(i = 0; i < length; i++) {
        printf("%d ", startBlock + i);
    }

    printf("\n");

    return 0;
}
