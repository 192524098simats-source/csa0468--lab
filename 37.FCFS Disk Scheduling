#include <stdio.h>
#include <stdlib.h>

int main() {

    int n, head;
    int seek_time = 0;

    printf("Enter number of requests: ");
    scanf("%d", &n);

    int request[n];

    printf("Enter request queue:\n");

    for(int i=0;i<n;i++)
        scanf("%d",&request[i]);

    printf("Enter initial head position: ");
    scanf("%d",&head);

    printf("\nHead Movement:\n%d", head);

    for(int i=0;i<n;i++) {

        seek_time += abs(head - request[i]);

        head = request[i];

        printf(" -> %d", head);
    }

    printf("\nTotal Seek Time = %d\n", seek_time);

    printf("Average Seek Time = %.2f\n",
           (float)seek_time/n);

    return 0;
}
