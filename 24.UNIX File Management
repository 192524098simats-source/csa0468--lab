#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <fcntl.h>
#include <sys/types.h>
#include <sys/stat.h>

int main() {

    int fd;
    char buffer[100];

    // Create a file
    fd = creat("sample.txt", S_IRWXU);

    if (fd == -1) {
        perror("creat");
        exit(1);
    }

    printf("File 'sample.txt' created successfully.\n");
    close(fd);

    // Open file for writing
    fd = open("sample.txt", O_WRONLY | O_APPEND);

    if (fd == -1) {
        perror("open");
        exit(1);
    }

    printf("File 'sample.txt' opened for writing.\n");

    write(fd, "Hello, World!\n", 14);

    printf("Data written to file.\n");

    close(fd);

    // Open file for reading
    fd = open("sample.txt", O_RDONLY);

    if (fd == -1) {
        perror("open");
        exit(1);
    }

    printf("File 'sample.txt' opened for reading.\n");

    int bytesRead = read(fd, buffer, sizeof(buffer));

    printf("Data read from file:\n");

    write(STDOUT_FILENO, buffer, bytesRead);

    close(fd);

    // Delete file
    if (remove("sample.txt") == 0)
        printf("\nFile deleted successfully.\n");
    else
        printf("\nError deleting file.\n");

    return 0;
}
