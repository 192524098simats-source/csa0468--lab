#include <stdio.h>
#include <stdlib.h>

int main() {

    int n, head;
    int seek_time = 0;

    printf("Enter number of requests: ");
    scanf("%d",&n);

    int req[n];

    printf("Enter request queue:\n");

    for(int i=0;i<n;i++)
        scanf("%d",&req[i]);

    printf("Enter initial head position: ");
    scanf("%d",&head);

    for(int i=0;i<n-1;i++) {
        for(int j=i+1;j<n;j++) {

            if(req[i] > req[j]) {

                int temp = req[i];
                req[i] = req[j];
                req[j] = temp;
            }
        }
    }

    for(int i=0;i<n;i++) {

        seek_time += abs(head - req[i]);

        head = req[i];
    }

    printf("Total Seek Time = %d\n", seek_time);

    printf("Average Seek Time = %.2f\n",
           (float)seek_time/n);

    return 0;
}
